%%{init: {'theme':'base', 'themeVariables': { 'primaryColor':'#2E86AB', 'errorBkgColor':'#D62828', 'warningBkgColor':'#F77F00', 'successBkgColor':'#52B788'}}}%%

stateDiagram-v2
    [*] --> Closed: Initial State

    state "Circuit Breaker Pattern" as CB {
        state "CLOSED" as Closed
        state "OPEN" as Open
        state "HALF-OPEN" as HalfOpen

        Closed : Allow all requests
        Closed : Reset failure count on success
        Closed : Track consecutive failures

        Open : Block all requests immediately
        Open : Return cached "unavailable" error
        Open : Wait for timeout period (30s)

        HalfOpen : Allow single test request
        HalfOpen : Success → CLOSED
        HalfOpen : Failure → OPEN

        Closed --> Open : 5 consecutive failures
        Open --> HalfOpen : After 30s timeout
        HalfOpen --> Closed : Success
        HalfOpen --> Open : Failure
    }

    state "Retry Logic" as RL {
        state "Error Classification" as EC
        state "Exponential Backoff" as EB
        state "Smart Decision" as SD

        EC : Analyze HTTP status code
        EC : 404, 401, 403 → Permanent
        EC : 500, 502, 503, timeout → Transient
        EC : Network errors → Transient

        EB : Initial delay: 100ms
        EB : Multiplier: 2x
        EB : Max delay: 3.2s
        EB : Max attempts: 5
        EB : Formula: min(100ms * 2^attempt, 3.2s)

        SD : Permanent error → No retry, delete message
        SD : Transient error → Retry with backoff
        SD : Max retries → Send to DLQ
    }

    state "Cache Strategy" as CS {
        state "Installation Registry" as IR
        state "TTL Management" as TM
        state "Cache Metrics" as CM

        IR : Positive cache (installed): 1 hour TTL
        IR : Negative cache (not installed): 5 min TTL
        IR : LRU eviction when full
        IR : Thread-safe concurrent access

        TM : Auto-expire stale entries
        TM : Refresh on access if expired
        TM : Background cleanup routine

        CM : Hit rate: 90% average
        CM : API call reduction: 40%
        CM : Size: ~1000 entries typical
    }

    state "Error Handling Flow" as EH {
        Request --> CheckCircuit : API Request

        state CheckCircuit <<choice>>
        CheckCircuit --> CheckCache : Circuit CLOSED
        CheckCircuit --> ReturnError : Circuit OPEN

        state CheckCache <<choice>>
        CheckCache --> ReturnCached : Cache HIT (90%)
        CheckCache --> CallAPI : Cache MISS

        state CallAPI <<choice>>
        CallAPI --> UpdateCache : Success
        CallAPI --> ClassifyError : Failure

        state ClassifyError <<choice>>
        ClassifyError --> NoRetry : Permanent Error
        ClassifyError --> RetryBackoff : Transient Error

        state RetryBackoff <<choice>>
        RetryBackoff --> CallAPI : Attempt < 5
        RetryBackoff --> DLQ : Max Retries

        UpdateCache --> Success : Update cache & reset circuit
        ReturnCached --> Success : Return cached data
        NoRetry --> Failed : Delete message
        DLQ --> Failed : Move to dead letter queue
        ReturnError --> Failed : Fast fail
    }

    state "Performance Impact" as PI {
        Before : 5-10% event loss
        Before : No retry on failures
        Before : 100% API calls
        Before : 10 min MTTR

        After : 0% event loss
        After : Smart retry with backoff
        After : 60% API calls (40% cached)
        After : 2 min MTTR

        Before --> After : Resilience Patterns Applied
    }
